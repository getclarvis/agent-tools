{
  "name": "@clarvis/agent-tools",
  "version": "0.3.0",
  "description": "A minimal, opinionated set of coding tools for driving an LLM agent over a workspace — read/write/edit/patch/move, batch read, grep/glob/diff, project-wide regex replace, bash + background monitors, and tree-sitter-powered outline/check_syntax — usable as a plain library.",
  "license": "MIT",
  "keywords": [
    "llm",
    "agent",
    "ai-agent",
    "coding-agent",
    "agent-tools",
    "tool-use",
    "coding-tools",
    "filesystem",
    "grep",
    "ripgrep",
    "apply-patch",
    "diff",
    "codemod",
    "bash",
    "workspace",
    "typescript",
    "tree-sitter",
    "syntax"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./guard": {
      "types": "./dist/guard/index.d.ts",
      "import": "./dist/guard/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "SPEC.md",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "pre-commit": "npm run typecheck && npm run format:check && npm run test:coverage",
    "prepublishOnly": "test -f README.md && test -f SPEC.md && npm run build && npm test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "diff": "^9.0.0",
    "ignore": "^7.0.5",
    "tinyglobby": "^0.2.10"
  },
  "peerDependencies": {
    "@vscode/tree-sitter-wasm": "^0.3.1"
  },
  "peerDependenciesMeta": {
    "@vscode/tree-sitter-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getclarvis/agent-tools.git"
  },
  "homepage": "https://github.com/getclarvis/agent-tools#readme",
  "bugs": {
    "url": "https://github.com/getclarvis/agent-tools/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
